{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "outDir": "./built",
    "esModuleInterop": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "target": "ES2020",
    "baseUrl": ".",

    "jsx": "preserve",
    "moduleResolution": "bundler",
    "types": ["vite/client", "node", "vitest/globals"],
    "skipLibCheck": true,
    "module": "esnext",
    "strict": true,
    "paths": {
      "@/*": ["./src/*"],
      "test-unit/*": ["./test-unit/*"]
    }
  },
  "include": [
    "./src/**/*",
    "./test/**/*",
    "./test-e2e/**/*",
    "./test-unit/**/*",
    "./test-integration/**/*",
    "./playwright.config.ts"
  ]
}
